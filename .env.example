# Credit Signal Report — environment configuration
# Copy to .env and adjust for your local setup.

# --- Database (local PostgreSQL 17) ---
# The app creates a separate database from the marketing-service.
# Create it once:  CREATE DATABASE credit_signal_report;
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/credit_signal_report

# --- API ---
PORT=8120
ENVIRONMENT=dev

# --- GSTIN validation ---
# When true, the 15th check-digit of every GSTIN is verified.
# Set false if you want to feed made-up test GSTINs that don't carry a valid checksum.
VALIDATE_GSTIN_CHECKSUM=true

# --- GST data provider ---
# "mock"    -> realistic fake data, zero cost, works offline (default).
# "sandbox" -> Sandbox.co.in (Quicko): real GST data, self-serve & free to start.
# "perfios" -> Perfios/Karza sandbox/production API.
GST_PROVIDER=mock

# Sandbox.co.in credentials (only needed when GST_PROVIDER=sandbox).
# Sign up at https://sandbox.co.in to get an API key + secret.
SANDBOX_BASE_URL=https://api.sandbox.co.in
SANDBOX_API_KEY=
SANDBOX_API_SECRET=
SANDBOX_API_VERSION=1.0.0
# Financial year for the compliance (returns-tracking) call, e.g. "FY 2025-26".
# Leave empty to auto-detect the current Indian FY.
SANDBOX_FINANCIAL_YEAR=

# Perfios sandbox credentials (only needed when GST_PROVIDER=perfios).
# Perfios offers 10,000+ free sandbox credits — same stack as Karza.
# Confirm the exact base URL, path, and auth header from your sandbox docs.
PERFIOS_BASE_URL=https://sandbox.perfios.ai
PERFIOS_API_KEY=
PERFIOS_AUTH_HEADER=x-api-key
PERFIOS_GST_PATH=/gst/v1/search
PERFIOS_CONSENT=Y

# --- MCA + legal data provider (Phase 3) ---
# "mock" -> realistic fake company/directors/charges/legal data (default, offline).
# Real providers (MCA21 aggregators + NJDG/IBBI) drop in behind the same interface.
MCA_PROVIDER=mock
# How long MCA/legal responses stay fresh in the shared cache (days).
MCA_CACHE_TTL_DAYS=30
